# ── Modo Demo ─────────────────────────────────────────────────────────────────
# Activa el modo demo: no requiere PostgreSQL ni OAuth.
# Muestra datos ficticios y permite tomar capturas para portfolio.
NEXT_PUBLIC_DEMO_MODE=true

# ── Base de datos ──────────────────────────────────────────────────────────────
# Requerida solo cuando NEXT_PUBLIC_DEMO_MODE=false
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:password@localhost:5432/auth_db"

# ── Auth.js ────────────────────────────────────────────────────────────────────
# Genera un valor seguro con: npx auth secret
AUTH_SECRET=""

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
# Crea una OAuth App en: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Crea credenciales en: https://console.cloud.google.com
# Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
